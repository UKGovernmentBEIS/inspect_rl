# Copy to .env and fill in. The sbatches in examples/configs/ pass these
# through to the trainer; the justfile reads them for `setup-slurm-hpc`.
#
# `.env` is gitignored — never commit real values.

# --- Weights & Biases ---
# Required when you pass --wandb to `irl train` or set WANDB=1 in the
# sbatches. WANDB_BASE_URL is the host you `wandb login --host` against
# (e.g. https://api.wandb.ai for the SaaS, or your private endpoint).
WANDB_BASE_URL=
WANDB_API_KEY=
WANDB_ENTITY=

# --- Kubernetes / EKS (used by `just setup-slurm-hpc`) ---
# AWS EKS cluster name and the namespace prefix to scope kubectl to.
AWS_EKS_CLUSTER=
K8S_NAMESPACE_USER=
